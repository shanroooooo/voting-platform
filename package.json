{
  "name": "food-delivery-platform",
  "version": "1.0.0",
  "description": "Food Delivery & Logistics Platform with React Native, Node.js, Redis, and MongoDB",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "client": "cd frontend && npm start",
    "mobile": "cd mobile && npx react-native start",
    "mobile-android": "cd mobile && npx react-native run-android",
    "mobile-ios": "cd mobile && npx react-native run-ios",
    "build": "cd backend && npm run build",
    "test": "cd backend && npm test",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "keywords": [
    "food-delivery",
    "react-native",
    "nodejs",
    "mongodb",
    "redis",
    "logistics",
    "real-time"
  ],
  "author": "Capstone Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "redis": "^4.6.7",
    "socket.io": "^4.7.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^6.8.1",
    "multer": "^1.4.5-lts.1",
    "stripe": "^13.6.0",
    "@googlemaps/google-maps-services-js": "^3.3.42",
    "twilio": "^4.14.0",
    "nodemailer": "^6.9.4",
    "joi": "^17.9.2",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "supertest": "^6.3.3"
  }
}
