{
  "name": "food-delivery-backend",
  "version": "1.0.0",
  "description": "Backend API for Food Delivery Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
